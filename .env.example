# ==========================================
# INTEGRACAO MOS BR (Telefonia / TVOZ / URA)
# Credenciais de acesso a API MOS BR.
# As mesmas usadas para login no painel em:
#   https://plataforma.mosbr.io
#
# A autenticacao e feita via Basic Auth (usuario:senha).
# Estas variaveis sao usadas pela Edge Function:
#   supabase/functions/ura-campaign-sync/index.ts
# ==========================================
MOS_BR_USER="seu-usuario-mosbr"
MOS_BR_PASS="sua-senha-mosbr"

